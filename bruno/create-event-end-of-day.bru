meta {
  name: Create Event - End of Day
  type: http
  seq: 3
}

post {
  url: {{BASE_URL}}/event
  body: json
  auth: bearer
}

auth:bearer {
  token: {{BEARER_TOKEN}}
}

body:json {
  {
    "text": "Meeting from 2pm until end of day tomorrow"
  }
}

tests {
  res.status == 201
  res.body.event_url != ""
}
